{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReferenceQuestionsByCapability",
  "description": "Reference questions grouped under the capability each question evaluates",
  "type": "object",
  "required": ["service_id", "service_name", "capability_questions"],
  "properties": {
    "service_id": { "type": "string" },
    "service_name": { "type": "string" },
    "capability_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["capability_id", "capability_name", "questions"],
        "properties": {
          "capability_id": { "type": "string", "pattern": "^erm-" },
          "capability_name": { "type": "string", "minLength": 1 },
          "questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "prompt", "intent", "field_key"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^rq-erm-[0-9]{2}-[0-9]+$"
                },
                "prompt": { "type": "string", "minLength": 1 },
                "intent": { "type": "string", "minLength": 1 },
                "field_key": { "type": "string", "pattern": "^erm_" },
                "evaluation_focus": { "type": "string" },
                "assessment_dimension": {
                  "type": "string",
                  "enum": [
                    "documented",
                    "implemented",
                    "automatable",
                    "integrated",
                    "monitored"
                  ]
                },
                "dependency_type": {
                  "type": "string",
                  "enum": [
                    "independent",
                    "subject_bound",
                    "mode_bound",
                    "ecosystem_bound"
                  ]
                },
                "default_subject": { "type": "string" },
                "subject_fallbacks": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "probe_on": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "probe_hints": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "operating_context_keys": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "reframe_rules": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
