{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReferenceQuestionsByCapability",
  "description": "Reference questions grouped under the capability each question evaluates",
  "type": "object",
  "required": ["service_id", "service_name", "capability_questions"],
  "properties": {
    "service_id": { "type": "string" },
    "service_name": { "type": "string" },
    "capability_questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["capability_id", "capability_name", "questions"],
        "properties": {
          "capability_id": { "type": "string", "pattern": "^issp-" },
          "capability_name": { "type": "string", "minLength": 1 },
          "questions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "prompt", "intent", "field_key"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^rq-issp-[0-9]{2}-[0-9]+$"
                },
                "prompt": { "type": "string", "minLength": 1 },
                "intent": { "type": "string", "minLength": 1 },
                "field_key": { "type": "string", "pattern": "^issp_" },
                "evaluation_focus": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
