# =============================================================================
# Root environment template — copy sections into service folders or export
# =============================================================================

# --- OpenAI (required for LLM evaluation) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://your-endpoint/openai/v1

# --- Backend gateway (backend/.env) ---
CONVERSATION_SERVICE_URL=http://localhost:8001
ASSESSMENT_SERVICE_URL=http://localhost:8002
FRAMEWORK_SERVICE_URL=http://localhost:8003
LLM_CONVERSATION_SERVICE_URL=http://localhost:8004

# --- LLM conversation (services/llm-conversation/.env) ---
# Uses OPENAI_API_KEY and OPENAI_MODEL from above
EVALUATION_SERVICE_DIR=../../evaluation-services/Information Security Strategy and Planning Services

# --- UI (ui/.env) ---
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=

# --- Backend auth (backend/.env) ---
GOOGLE_CLIENT_ID=
JWT_SECRET=
JWT_EXPIRE_MINUTES=1440
AUTH_REQUIRED=false
DATABASE_URL=postgresql://user:pass@localhost:5432/dra
