# Copy to .env in each folder or export for local development (no Docker).

# Backend (backend/.env)
CONVERSATION_SERVICE_URL=http://localhost:8001
ASSESSMENT_SERVICE_URL=http://localhost:8002
FRAMEWORK_SERVICE_URL=http://localhost:8003
LLM_CONVERSATION_SERVICE_URL=http://localhost:8004

# LLM conversation (services/llm-conversation/.env) — add your key here
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://your-endpoint/openai/v1
EVALUATION_SERVICE_DIR=../../evaluation-services/Information Security Strategy and Planning Services

# Conversation & assessment services
# FRAMEWORK_SERVICE_URL=http://localhost:8003

# UI (ui/.env) — baked in at build time for production static deploys
VITE_API_URL=http://localhost:8000
